-- For moonshot-58M (J24D architecture with D=512, J=24),
-- use EMA_INIT = 1/δ_relay_min = 1/48
def EMA_INIT_J24D : Float := 1.0 / 48.0
#eval EMA_INIT_J24D  -- Should output 0.020833333333333332

-- Window size for interpretation
#eval round (1.0 / EMA_INIT_J24D)  -- Should output 48

-- EMA_INIT for moonshot-58M (J24D with 512-dim residual stream)
-- This is the recommended initialization value
def EMA_INIT_MOONSHOT_58M : Float := 1.0 / 48.0
