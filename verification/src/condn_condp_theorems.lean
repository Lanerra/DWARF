-- Theorem 6: The offsets [33..47] are NOT in condN but ARE in condP.
-- ∀ d ∈ [33,47], d ∉ condN_offsets ∧ d ∈ condP_offsets.
-- (This directly proves condP fixes the structural bottleneck condN left open)
theorem bottleneck_structural :
    ∀ d : Nat, d ∈ List.range 33 48 → 
      (d ∉ condN_offsets ∧ d ∈ condP_offsets) := by
  intro d hd
  simp [condN_offsets, condP_offsets, List.mem_range] at hd ⊢
  cases hd with
  | intro h1 h2 =>
    interval_cases d <;> decide

-- Helper: Count total unique lags reachable in ≤maxHops
def count_reachable_within (offsets : List Nat) (maxHops : Nat) : Nat :=
  let lags := List.range 1 N
  lags.filter (fun d => reachableWithinHops offsets d maxHops) |>.length
