-- Summary theorem: δ=5 is the sole 2-hop carrier for all passkey distances d ∈ {8,16,256,512,1024}
-- This explains the "dual-edged" ablation profile:
-- - d=8, d=16: Removing δ=5 eliminates the shortcut but somehow IMPROVES performance (+30pp each)
--   Possibly because δ=5 interferes with direct capacity or creates suboptimal attention patterns
-- - d=256, d=512, d=1024: Removing δ=5 eliminates the ONLY 2-hop path, HARMING performance (-50pp)
--   No alternatives exist, so model cannot compensate
theorem delta5_dual_edged_summary :
    (∀ d ∈ [8, 16, 256, 512, 1024], 
      find_two_hop_pairs j13d_offsets (d + 5) = [(5, d)] ∧
      find_two_hop_pairs j13d_offsets_ablated (d + 5) = []) := by
  intro d hd
  simp at hd
  cases hd with
  | inl h => 
    -- d = 8
    rw [h]
    exact delta5_sole_path_d8
  | inr h => cases h with
    | inl h => 
      -- d = 16
      rw [h]
      exact delta5_sole_path_d16
    | inr h => cases h with
      | inl h => 
        -- d = 256
        rw [h]
        exact delta5_sole_path_d256
      | inr h => cases h with
        | inl h => 
          -- d = 512
          rw [h]
          exact delta5_sole_path_d512
        | inr h => 
          -- d = 1024
          rw [h]
          exact delta5_sole_path_d1024

