import Mathlib.Data.List.Basic
import Mathlib.Data.Nat.Basic

-- Sequence length
def N : Nat := 2048

-- A "distance" d is reachable in k hops from offset set O if d can be
-- written as a sum of exactly k elements of O (with repetition allowed).
-- Equivalently: BFS from 0 over the additive monoid generated by O.
def reachableInHops (offsets : List Nat) (d : Nat) (maxHops : Nat) : Bool :=
  let rec go (frontier : List Nat) (visited : List Nat) (hopsLeft : Nat) : Bool :=
    if hopsLeft == 0 then frontier.contains d
    else
      let next := frontier.flatMap (fun x => offsets.map (fun o => x + o))
        |>.filter (fun x => x <= d && !visited.contains x)
        |>.eraseDups
      if next.contains d then true
      else go next (visited ++ next) (hopsLeft - 1)
  go [0] [0] maxHops

-- J13D offset set
def j13d_offsets : List Nat := [1, 2, 4, 5, 8, 16, 32, 64, 128, 256, 512, 768, 1024]

-- Passkey distances
def passkey_distances : List Nat := [1, 2, 4, 8, 16, 32, 64, 128, 256, 512, 1024, 1536]

-- Passkey gaps (d + 5)
def passkey_gaps : List Nat := passkey_distances.map (· + 5)

-- Theorem 1: For all passkey distances d in [1,2,4,8,16,32,64,128,256,512,1024],
-- the gap d+5 is 2-hop reachable from J13D offsets.
-- This means 11 out of 12 passkey distances are 2-hop covered.
theorem j13d_two_hop_coverage_11_of_12 :
    ∀ d ∈ passkey_distances.filter (· ≠ 1536), reachableInHops j13d_offsets (d + 5) 2 = true := by
  intro d hd
  simp only [passkey_distances, j13d_offsets, List.mem_filter, List.mem_cons, List.mem_singleton,
    List.mem_append, List.mem_map] at hd ⊢
  -- Filter out d=1536
  cases hd with
  | inl h => 
    -- d = 1, gap = 6
    simp [reachableInHops, h]
    decide
  | inr h => cases h with
    | inl h => 
      -- d = 2, gap = 7
      simp [reachableInHops, h]
      decide
    | inr h => cases h with
      | inl h => 
        -- d = 4, gap = 9
        simp [reachableInHops, h]
        decide
      | inr h => cases h with
        | inl h => 
          -- d = 8, gap = 13
          simp [reachableInHops, h]
          decide
        | inr h => cases h with
          | inl h => 
            -- d = 16, gap = 21
            simp [reachableInHops, h]
            decide
          | inr h => cases h with
            | inl h => 
              -- d = 32, gap = 37
              simp [reachableInHops, h]
              decide
            | inr h => cases h with
              | inl h => 
                -- d = 64, gap = 69
                simp [reachableInHops, h]
                decide
              | inr h => cases h with
                | inl h => 
                  -- d = 128, gap = 133
                  simp [reachableInHops, h]
                  decide
                | inr h => cases h with
                  | inl h => 
                    -- d = 256, gap = 261
                    simp [reachableInHops, h]
                    decide
                  | inr h => cases h with
                    | inl h => 
                      -- d = 512, gap = 517
                      simp [reachableInHops, h]
                      decide
                    | inr h => cases h with
                      | inl h => 
                        -- d = 1024, gap = 1029
                        simp [reachableInHops, h]
                        decide
                      | inr h => 
                        -- This case should not happen due to filter
                        contradiction

-- Theorem 2: The gap for d=1536 (which is 1541) requires at least 3 hops,
-- but IS 3-hop reachable. Specifically: 768 + 768 + 5 = 1541, and all three values are in J13D.
theorem j13d_d1536_three_hop :
    reachableInHops j13d_offsets 1541 3 = true ∧
    768 ∈ j13d_offsets ∧ 5 ∈ j13d_offsets ∧ 768 + 768 + 5 = 1541 := by
  constructor
  · -- Show 1541 is 3-hop reachable
    simp [reachableInHops, j13d_offsets]
    decide
  constructor
  · -- Show 768 is in J13D offsets
    simp [j13d_offsets]
  constructor
  · -- Show 5 is in J13D offsets
    simp [j13d_offsets]
  · -- Show 768 + 768 + 5 = 1541
    norm_num

-- Theorem 3: 1541 is NOT 2-hop reachable from J13D offsets.
-- (Exhaustive check: no pair a+b from J13D equals 1541)
theorem j13d_d1536_not_two_hop :
    reachableInHops j13d_offsets 1541 2 = false := by
  simp [reachableInHops, j13d_offsets]
  decide

-- Comment on what these theorems mean for the paper claim:
-- "J13D achieves 2-hop coverage of 11/12 passkey distances; d=1536 requires 3 hops via 768+768+5."

-- Ablated offset set (δ=5 removed)
def j13d_offsets_ablated : List Nat := [1, 2, 4, 8, 16, 32, 64, 128, 256, 512, 768, 1024]

-- Helper: Check if a 2-hop path exists using exactly the specified pair
def has_exact_two_hop_path (offsets : List Nat) (a b : Nat) (gap : Nat) : Bool :=
  if a + b == gap then
    a ∈ offsets && b ∈ offsets && (a ≠ b ∨ offsets.count a ≥ 2)
  else false

-- Helper: Find all 2-hop pairs that sum to a given gap
def find_two_hop_pairs (offsets : List Nat) (gap : Nat) : List (Nat × Nat) :=
  let validPairs := offsets.flatMap (fun a => 
    offsets.map (fun b => (a, b)) 
    |>.filter (fun (a, b) => a + b == gap && a ≤ b))
  validPairs.eraseDups

-- Theorem 4: δ=5 provides THE ONLY 2-hop path for gap=261 (d=256)
-- The only pair is (5, 256), and 5 is not in the ablated set
theorem delta5_sole_path_d256 :
    find_two_hop_pairs j13d_offsets 261 = [(5, 256)] ∧
    find_two_hop_pairs j13d_offsets_ablated 261 = [] := by
  constructor
  · -- Show that (5, 256) is the only pair in J13D
    simp [find_two_hop_pairs, j13d_offsets]
    decide
  · -- Show that no pair exists in ablated set
    simp [find_two_hop_pairs, j13d_offsets_ablated]
    decide

